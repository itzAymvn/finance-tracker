APP_NAME="Salary Tracker"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://payroll.aymvn.net

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Optional seed user (run: php artisan db:seed --class=Database\\Seeders\\UserSeeder)
# SEED_USER_EMAIL=
# SEED_USER_PASSWORD=
# SEED_USER_NAME=
